# Désactiver le listing des répertoires
Options -Indexes

RewriteEngine on

# Redirection non-www → www
RewriteCond %{HTTP_HOST} ^funny-creche\.fr [NC]
RewriteRule ^(.*)$ https://www.funny-creche.fr/$1 [L,R=301]

# Bloquer l'accès direct aux vues PHP (sécurité)
RewriteRule ^views/.*\.php$ - [F,L]

# URLs propres
RewriteRule ^creches\.html$ index.php?mode=creches [QSA,L]
RewriteRule ^contact\.html$ index.php?mode=contact [QSA,L]
RewriteRule ^contact\.php$ /contact.html [R=301,L]
RewriteRule ^projet-pedagogique\.html$ index.php?mode=projet-pedagogique [QSA,L]
RewriteRule ^projet-pedagogique\.php$ /projet-pedagogique.html [R=301,L]
RewriteRule ^qu-est-ce-qu-une-micro-creche\.html$ index.php?mode=projet-pedagogique&anchor=micro-creche [QSA,L]
RewriteRule ^tarifs\.html$ index.php?mode=projet-pedagogique&anchor=tarifs [QSA,L]
RewriteRule ^creche-dijon\.html$ index.php?mode=creche-dijon [QSA,L]
RewriteRule ^creche-dijon\.php$ /creche-dijon.html [R=301,L]
RewriteRule ^creche-dijon-cazotte\.html$ index.php?mode=creche-dijon-cazotte [QSA,L]
RewriteRule ^creche-dijon-cazotte\.php$ /creche-dijon-cazotte.html [R=301,L]
RewriteRule ^creche-demigny\.html$ index.php?mode=creche-demigny [QSA,L]
RewriteRule ^creche-saint-loup\.html$ index.php?mode=creche-saint-loup [QSA,L]
RewriteRule ^creche-demigny\.php$ /creche-demigny.html [R=301,L]
RewriteRule ^creche-neuilly-sur-marne\.php$ /creche-neuilly-sur-marne.html [R=301,L]
RewriteRule ^creche-neuilly-sur-marne\.html$ index.php?mode=creche-neuilly-sur-marne [QSA,L]
RewriteRule ^creche-noisy-le-grand\.php$ /creche-noisy-le-grand.html [R=301,L]
RewriteRule ^creche-noisy-le-grand\.html$ index.php?mode=creche-noisy-le-grand [QSA,L]
RewriteRule ^creche-beaune-tonneliers\.php$ /creche-beaune-tonneliers.html [R=301,L]
RewriteRule ^creche-beaune-tonneliers\.html$ index.php?mode=creche-beaune-tonneliers [QSA,L]
RewriteRule ^creche-beaune-verdun\.php$ /creche-beaune-verdun.html [R=301,L]
RewriteRule ^creche-beaune-verdun\.html$ index.php?mode=creche-beaune-verdun [QSA,L]
RewriteRule ^creche-plombiere\.php$ /creche-plombiere.html [R=301,L]
RewriteRule ^creche-plombiere\.html$ index.php?mode=creche-plombiere [QSA,L]
RewriteRule ^creche-mont\.php$ /creche-mont.html [R=301,L]
RewriteRule ^creche-mont\.html$ index.php?mode=creche-mont [QSA,L]
RewriteRule ^ouvertures-prochaines\.html$ index.php?mode=ouvertures-prochaines [QSA,L]
RewriteRule ^creche-recrute$ /recrutement.html [R=301,L]
RewriteRule ^recrutement\.html$ index.php?mode=recrutement [QSA,L]
RewriteRule ^creche-varois\.php$ /creche-varois.html [R=301,L]
RewriteRule ^creche-varois\.html$ index.php?mode=creche-varois [QSA,L]
RewriteRule ^creche-nuits\.php$ /creche-nuits.html [R=301,L]
RewriteRule ^creche-nuits\.html$ index.php?mode=creche-nuits [QSA,L]
RewriteRule ^mentions-legales\.html$ index.php?mode=mentions-legales [QSA,L]

# Protection des fichiers sensibles
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>

<FilesMatch "(composer\.json|composer\.lock|package\.json|package-lock\.json|\.gitignore|CLAUDE\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# En-têtes de sécurité HTTP
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header unset X-Powered-By
</IfModule>

# Cache navigateur pour les assets statiques
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/gif "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Compression Gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
